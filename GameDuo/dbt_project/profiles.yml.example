# 이 파일은 예시입니다. 실제 실행 시 ~/.dbt/profiles.yml 로 복사하고
# 본인의 GCP 서비스 계정 키 경로를 채워 넣어야 합니다.
gameduo_analytics:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: newproject-502815
      dataset: dungeon_game_analytics
      threads: 4
      keyfile: /path/to/your/service-account-key.json
      location: US
